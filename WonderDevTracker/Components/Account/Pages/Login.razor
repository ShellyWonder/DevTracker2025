@*Login*@
@page "/Account/Login"

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject IConfiguration Configuration

<PageTitle>Login | Dev Tracker</PageTitle>

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <AnimatedCard Elevation="1"
                      Index="@IndexTracker.Peek()">
            <div class="d-flex align-items-center justify-content-center">
                <div class="vstack p-3">
                    <TitleComponentPage Subtitle="Login"
                                        SubtitleTypo="Typo.h4"
                                        SubtitleColor="Color.Secondary">
                        <TitleTemplate>
                            Welcome to <AppLogoText />
                        </TitleTemplate>
                    </TitleComponentPage>
                    <StatusMessage Message="@errorMessage" />
                    <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                        <DataAnnotationsValidator />
                        <hr />
                        <ValidationSummary class="text-danger" role="alert" />
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <div class="mb-3">
                                <MudTextField id="Email"
                                              @bind-Value="Input.Email"
                                              name="Input.Email"
                                              Label="Email"
                                              For="() => Input.Email"
                                              autocomplete="username"
                                              aria-required="true"
                                              aria-label="Email Sign-in"
                                              Placeholder="name@example.com"
                                              Variant="Variant.Outlined"
                                              ShrinkLabel />
                            </div>
                        </AnimatedBlock>
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <div class="mb-3">
                                <PasswordField @bind-Value="Input.Password"
                                               Label="Password"
                                               Name="Input.Password"
                                               Autocomplete="current-password" />
                                <ValidationMessage For="() => Input.Password" />
                            </div>
                        </AnimatedBlock>
                        <div class="form-check remember-me-row mb-3">
                            <InputCheckbox id="remember-me"
                                           @bind-Value="Input.RememberMe"
                                           class="form-check-input darker-border-checkbox remember-me-checkbox" />

                            <label class="form-check-label remember-me-label" for="remember-me">
                                Remember me
                            </label>
                        </div>
                        <!------ Login Button ------>
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <SubmitBtn Size="Size.Large"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Login"
                                       ButtonType="ButtonType.Submit"
                                       DisplayText="Login"
                                       FullWidth="true" />
                        </AnimatedBlock>
                    </EditForm>

                    <!------ Demo Login Options ------>
                    <AnimatedBlock Index="IndexTracker.Next()">
                        <div class="login-demo-panel">
                            <TitleComponentPage SubtitleColor="Color.Secondary"
                                                SubtitleAlign="Align.Center"
                                                SubtitleTypo="Typo.h6"
                                                Subtitle="Choose a role to explore DevTracker."
                                                Title="Demo Company Login"
                                                Typo="Typo.h4"
                                                Align="Align.Center"
                                                Color="Color.Dark" />

                            <EditForm Model="@DemoInput"
                                      method="post"
                                      FormName="demo-login"
                                      OnSubmit="LoginDemoUserFromFormAsync"
                                      Enhance="false">
                                <div class="demo-login-grid">
                                    @foreach (DemoOptions option in DemoLoginOptions)
                                    {
                                        <button type="submit"
                                                name="DemoInput.Role"
                                                value="@option.Role"
                                                class="demo-login-submit-button demo-login-submit-button-@option.Role.ToString().ToLowerInvariant()">
                                            <MudIcon Icon="@option.Icon" Size="Size.Small" Class="me-2" />
                                            <span>@option.Label</span>
                                        </button>
                                    }
                                </div>
                            </EditForm>
                        </div>
                    </AnimatedBlock>
                    <!------ Account Help Actions ------>
                    <MudStack Row="true"
                              Justify="Justify.SpaceBetween"
                              Spacing="3"
                              Class="login-inline-links flex-wrap">
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <LinksBtn Href="Account/ForgotPassword"
                                      Color="Color.Dark"
                                      Variant="Variant.Text"
                                      StartIcon="@Icons.Material.Filled.LockReset"
                                      Text="Forgot Password?" />
                        </AnimatedBlock>

                        <AnimatedBlock Index="IndexTracker.Next()">
                            <LinksBtn Href="Account/ResendEmailConfirmation"
                                      Color="Color.Dark"
                                      Variant="Variant.Text"
                                      StartIcon="@Icons.Material.Filled.Mail"
                                      Text="Resend Email" />
                        </AnimatedBlock>

                        <AnimatedBlock Index="IndexTracker.Next()">
                            <LinksBtn Href="@NewUserRegister"
                                      Color="Color.Dark"
                                      Variant="Variant.Text"
                                      StartIcon="@Icons.Material.Filled.PersonAdd"
                                      Text="Register" />
                        </AnimatedBlock>
                    </MudStack>
                </div>
            </div>
        </AnimatedCard>
    </MudContainer>
</div>

@code {
    private string? errorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "login")]
    private InputModel Input { get; set; } = null!;

    [SupplyParameterFromForm(FormName = "demo-login")]
    private DemoLoginInputModel DemoInput { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "demoRole")]
    private string? DemoRole { get; set; }

    private IndexTrackerHelper IndexTracker = new();

    private void ResetIndex() => IndexTracker.Reset();

    private bool _demoLoginStarted;

    private string NewUserRegister => NavigationManager.GetUriWithQueryParameters("Account/Register",
                                      new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl });

    protected override async Task OnInitializedAsync()
    {
        ResetIndex();
        Input ??= new();
        DemoInput ??= new();

        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_demoLoginStarted || string.IsNullOrWhiteSpace(DemoRole))
            return;

        _demoLoginStarted = true;
        await LoginDemoUserFromQueryAsync(DemoRole);
    }

    public async Task LoginUser()
    {
        // This doesn't count login failures towards account lockout
        // To enable password failures to trigger account lockout, set lockoutOnFailure: true
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            var redirectUrl = string.IsNullOrWhiteSpace(ReturnUrl)
                                        ? "/dashboard"
                                        : ReturnUrl;

            RedirectManager.RedirectTo(redirectUrl);
            return;
        }


        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private async Task LoginDemoUserAsync(Role role)
    {
        string email = DemoEmails[role];
        string password = Configuration["DemoUsers:DefaultPassword"] ?? string.Empty;

        var result = await SignInManager.PasswordSignInAsync(
            email,
            password,
            isPersistent: false,
            lockoutOnFailure: false);

        if (!result.Succeeded)
        {
            Logger.LogWarning("Demo login failed for {DemoRole} using {DemoEmail}.", role, email);
            return;
        }

        Logger.LogInformation("Demo login succeeded for {DemoRole}. Redirecting to dashboard.", role);
        RedirectManager.RedirectTo("/dashboard");
    }

    private async Task LoginDemoUserFromQueryAsync(string demoRole)
    {
        if (!Enum.TryParse<Role>(demoRole, ignoreCase: true, out Role role) ||
            !DemoEmails.ContainsKey(role))
        {
            Logger.LogWarning("Invalid demo role requested: {DemoRole}", demoRole);
            return;
        }

        await LoginDemoUserAsync(role);
    }

    private static readonly Dictionary<Role, string> DemoEmails = new()
    {
        [Role.Admin] = "demoadmin@devtracker.com",
        [Role.ProjectManager] = "demopm@devtracker.com",
        [Role.Developer] = "demodev@devtracker.com",
        [Role.Submitter] = "demosubmitter@devtracker.com"
    };

    private static readonly IReadOnlyList<DemoOptions> DemoLoginOptions =
[
    new()
    {
        Role = Role.Admin,
        Label = "Demo Administrator",
        Icon = Icons.Material.Filled.AdminPanelSettings,
        Color = Color.Primary
    },

    new()
    {
        Role = Role.ProjectManager,
        Label = "Demo Project Manager",
        Icon = Icons.Material.Filled.ManageAccounts,
        Color = Color.Secondary
    },

    new()
    {
        Role = Role.Developer,
        Label = "Demo Developer",
        Icon = Icons.Material.Filled.Code,
        Color = Color.Tertiary
    },

    new()
    {
        Role = Role.Submitter,
        Label = "Demo Submitter",
        Icon = Icons.Material.Filled.BugReport,
        Color = Color.Info
    }
];

    private async Task LoginDemoUserFromFormAsync() => await LoginDemoUserAsync(DemoInput.Role);

    private sealed class DemoLoginInputModel
    {
        public Role Role { get; set; }
    }
    private sealed record DemoOptions
    {
        public Role Role { get; init; }
        public string Label { get; init; } = string.Empty;
        public string Icon { get; init; } = string.Empty;
        public Color Color { get; init; }
    }
    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}
