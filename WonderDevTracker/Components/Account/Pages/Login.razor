@*Login*@
@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.Extensions.Configuration
@using WonderDevTracker.Client.Components.UIComponents.GeneralComponents
@using WonderDevTracker.Client.Components.UIComponents.ProjectComponents
@using WonderDevTracker.Client.Helpers.Animation
@using Microsoft.AspNetCore.Identity
@using WonderDevTracker.Client.Components.SharedComponents

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject IConfiguration Configuration

<PageTitle>Log in | Dev Tracker</PageTitle>

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <MudContainer MaxWidth="MaxWidth.Medium">
        <AnimatedCard Elevation="1"
                      Index="@IndexTracker.Peek()">
            <div class="d-flex align-items-center justify-content-center">
                <div class="vstack p-3">
                    <TitleComponentPage Subtitle="Login"
                                        SubtitleTypo="Typo.h4"
                                        SubtitleColor="Color.Secondary">
                        <TitleTemplate>
                            Welcome to <AppLogoText />
                        </TitleTemplate>
                    </TitleComponentPage>
                    <StatusMessage Message="@errorMessage" />
                    <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                        <DataAnnotationsValidator />
                        <hr />
                        <ValidationSummary class="text-danger" role="alert" />
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <div class="mb-3">
                                <MudTextField id="Email"
                                              @bind-Value="Input.Email"
                                              name="Input.Email"
                                              Label="Email"
                                              For="() => Input.Email"
                                              autocomplete="username"
                                              aria-required="true"
                                              aria-label="Email Sign-in"
                                              Placeholder="name@example.com"
                                              Variant="Variant.Outlined"
                                              ShrinkLabel />
                            </div>
                        </AnimatedBlock>
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <div class="mb-3">
                                <PasswordField @bind-Value="Input.Password"
                                               Label="Password"
                                               Name="Input.Password"
                                               Autocomplete="current-password" />
                                <ValidationMessage For="() => Input.Password" />
                            </div>
                        </AnimatedBlock>
                        <div class="checkbox">
                            <label class="form-label">
                                <InputCheckbox @bind-Value="Input.RememberMe" class="darker-border-checkbox form-check-input" />
                                Remember me
                            </label>
                        </div>
                        <!------ Login Button ------>
                        <AnimatedBlock Index="IndexTracker.Next()">
                            <SubmitBtn Size="Size.Large"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Login"
                                       ButtonType="ButtonType.Submit"
                                       DisplayText="Login"
                                       FullWidth="true" />
                        </AnimatedBlock>

                        <!------ Demo Login Options ------>
                        <MudDivider Class="my-5" />
                        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-1">
                            Explore the Demo
                        </MudText>
                        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-3">
                            Choose a role to preview a role-specific dashboard.
                        </MudText>

                        <MudGrid Spacing="2">
                            @foreach (DemoLoginOption option in DemoLoginOptions)
                            {
                                <MudItem xs="12" sm="6">
                                    <SubmitBtn Href="@GetDemoLoginUrl(option.Role)"
                                               Size="Size.Medium"
                                               Color="@option.Color"
                                               StartIcon="@option.Icon"
                                               ButtonType="ButtonType.Button"
                                               Variant="Variant.Outlined"
                                               DisplayText="@option.Label"
                                               FullWidth="true" />
                                </MudItem>
                            }
                        </MudGrid>
                    </EditForm>
                </div>
            </div>
        </AnimatedCard>
        <!------ Account Help Actions ------>
        <MudStack Spacing="2" class="Mt-3">
            <AnimatedBlock Index="IndexTracker.Next()">
                <LinksBtn Href="Account/ForgotPassword"
                          Color="Color.Warning"
                          Variant="Variant.Text"
                          StartIcon="@Icons.Material.Filled.LockReset"
                          Text="Forgot your Password?" />
            </AnimatedBlock>

            <AnimatedBlock Index="IndexTracker.Next()">
                <SubmitBtn Href="Account/ResendEmailConfirmation"
                           Size="Size.Medium"
                           Color="Color.Secondary"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Mail"
                           ButtonType="ButtonType.Button"
                           DisplayText="Resend Email Confirmation" />
            </AnimatedBlock>

            <AnimatedBlock>
                <SubmitBtn Href="@NewUserRegister"
                           Size="Size.Medium"
                           Color="Color.Success"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           ButtonType="ButtonType.Button"
                           DisplayText="Register as a New User" />
            </AnimatedBlock>
        </MudStack>
    </MudContainer>
</div>
@code {
    private string? errorMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "demoRole")]
    private string? DemoRole { get; set; }

    private IndexTrackerHelper IndexTracker = new();

    private void ResetIndex() => IndexTracker.Reset();

    private string NewUserRegister => NavigationManager.GetUriWithQueryParameters("Account/Register",
                                      new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl });

    protected override async Task OnInitializedAsync()
    {
        ResetIndex();
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }

        if (!string.IsNullOrWhiteSpace(DemoRole))
        {
            await LoginDemoUserAsync(DemoRole);
        }
    }

    public async Task LoginUser()
    {
        // This doesn't count login failures towards account lockout
        // To enable password failures to trigger account lockout, set lockoutOnFailure: true
        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: false);
        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            var redirectUrl = string.IsNullOrWhiteSpace(ReturnUrl)
                                        ? "/dashboard"
                                        : ReturnUrl;

            RedirectManager.RedirectTo(redirectUrl);
        }


        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private async Task LoginDemoUserAsync(string demoRole)
    {
        if (!Enum.TryParse<Role>(demoRole, ignoreCase: true, out Role role) ||
            !DemoEmails.TryGetValue(role, out string? email))
        {
            return;
        }

        Input.Email = email;
        Input.Password = Configuration["DemoUsers:DefaultPassword"] ?? string.Empty;
        Input.RememberMe = false;

        var result = await SignInManager.PasswordSignInAsync(
            email,
            Input.Password,
            isPersistent: false,
            lockoutOnFailure: false);

        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("/dashboard");
        }
    }

    private static readonly Dictionary<Role, string> DemoEmails = new()
    {
        [Role.Admin] = "demoadmin@devtracker.com",
        [Role.ProjectManager] = "demopm@devtracker.com",
        [Role.Developer] = "demodev@devtracker.com",
        [Role.Submitter] = "demosubmitter@devtracker.com"
    };

    private static readonly IReadOnlyList<DemoLoginOption> DemoLoginOptions =
        [
            new(Role.Admin,
                "Demo Administrator",
                Icons.Material.Filled.AdminPanelSettings,
                Color.Primary),

            new(Role.ProjectManager,
                "Demo Project Manager",
                Icons.Material.Filled.ManageAccounts,
                Color.Info),

            new(Role.Developer,
                "Demo Developer",
                Icons.Material.Filled.Code,
                Color.Secondary),

            new(Role.Submitter,
                "Demo Submitter",
                Icons.Material.Filled.BugReport,
                Color.Success)
        ];

    private string GetDemoLoginUrl(Role role)
    {
        return NavigationManager.GetUriWithQueryParameters(
            "Account/Login",
            new Dictionary<string, object?>
            {
                ["demoRole"] = role.ToString(),
                ["ReturnUrl"] = ReturnUrl
            });
    }

    private sealed record DemoLoginOption(
            Role Role,
            string Label,
            string Icon,
            Color Color);

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }
}
