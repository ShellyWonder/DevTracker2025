@* TicketsIndex *@
@page "/tickets/assigned"
@page "/tickets/managed"


@attribute [Authorize(Roles = "Developer,ProjectManager")]

@inject ITicketDTOService ticketService
@inject ISnackbar Snackbar

@inherits AuthenticatedComponentBase

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4 page-container" Style="height: 100%; position: relative">
    <MudBreadcrumbs Items="breadcrumbs" Class="breadcrumbs1" />
    @if (!_loadingComplete)
    {
        <LoadingSpinner Message="Loading your tickets ..." Color="Color.Primary" Size="Size.Large" />
    }
    else if (tickets.Any())
    {
        <PageTitle>@PageState.BrowserTitle</PageTitle>
        <MudPaper Elevation="2" Class="p-3">
            <TitleComponentPage Title="@PageState.Heading" />

            <MudDivider Class="mb-3" />

            <TicketsTable Tickets="tickets"
                          CanAssignDeveloper="@PageState.CanAssignDeveloper" />
        </MudPaper>
    }
    else
    {
        <PageTitle>@PageState.BrowserTitle</PageTitle>
        <NotFoundFull Message="@PageState.EmptyMessage"
                      ReturnUrl="/dashboard"
                      ReturnLabel="Return to Dashboard"
                      ForwardUrl="/tickets/create"
                      ForwardLabel="Create New Ticket" />
    }

</MudContainer>


@code {
    private IEnumerable<TicketDTO> tickets = [];

    private bool _loadingComplete = false;

    protected override async Task OnInitializedWithAuthAsync()
    {
        try
        {
            await LoadTicketsAsync();

        }
        catch (Exception ex)
        {

            Console.WriteLine($"Error loading tickets: {ex.Message}");
            Snackbar.Add("Error loading tickets.", Severity.Error);
        }
        _loadingComplete = true;

    }

    private async Task LoadTicketsAsync()
    {
        if (UserIsInRole(Role.Developer))
        {
            tickets = await ticketService.GetOpenTicketsAssignedToDevAsync(UserInfo!);
            return;
        }

        if (IsProjectManager)
        {
            tickets = await ticketService.GetOpenManagedTicketsForPMAsync(UserInfo!);
            return;
        }

        tickets = [];
    }

    private TicketPageState PageState => GetPageState();

    private TicketPageState GetPageState()
    {
        if (UserIsInRole(Role.Developer))
        {
            return new TicketPageState(
                BrowserTitle: "My Assigned Tickets | Dev Tracker",
                Heading: "My Assigned Tickets",
                EmptyMessage: "You do not have any assigned tickets.",
                CanAssignDeveloper: false);
        }

        if (IsProjectManager)
        {
            return new TicketPageState(
                BrowserTitle: "My Managed Tickets | Dev Tracker",
                Heading: "My Managed Tickets",
                EmptyMessage: "You do not have any managed tickets.",
                CanAssignDeveloper: true);
        }

        return new TicketPageState(
            BrowserTitle: "Tickets Not Found | Dev Tracker",
            Heading: "Tickets",
            EmptyMessage: "Your tickets were not found.",
            CanAssignDeveloper: false);
    }
    private sealed record TicketPageState(
       string BrowserTitle,
       string Heading,
       string EmptyMessage,
       bool CanAssignDeveloper);

    private static readonly List<BreadcrumbItem> breadcrumbs = new()
    {
        new BreadcrumbItem("Dashboard", href:"/dashboard"),
        new BreadcrumbItem("Tickets", href:"/tickets/open" ),
        new BreadcrumbItem(" My Tickets", href:null, disabled: true ),

    };

    
}
