@* ProjectManagerChartsGrid.razor *@

<MudGrid Spacing="3">
	<MudItem xs="12" md="6">
		<DashboardEnumCountChart TEnum="TicketStatus"
								 Items="@Dashboard.PMChartData.TicketsByStatus"
								 Title="Tickets by Status"
								 Subtitle="Current managed ticket distribution by status."
								 EmptyStateMessage="No ticket status data available yet."
								 SeriesName="Tickets" />
	</MudItem>

	<MudItem xs="12" md="6">
		<DashboardEnumCountChart TEnum="ProjectPriority"
								 Items="@Dashboard.PMChartData.ProjectsByPriority"
								 Title="Projects by Priority"
								 Subtitle="Current managed project distribution by priority."
								 EmptyStateMessage="No project priority data available yet."
								 SeriesName="Projects" />
	</MudItem>

	<MudItem xs="12">
		<TicketsByProjectChart Items="Dashboard.PMChartData.TicketsByProject" />
	</MudItem>
</MudGrid>

@code {
	[Parameter, EditorRequired]
	public PMDashboardDTO Dashboard { get; set; } = default!;
}