@*AdminChartsGrid *@

<MudGrid Spacing="3">
	@* Chart A tickets by status *@
	<MudItem xs="12">
		<DashboardEnumCountChart TEnum="TicketStatus"
								 Items="@Dashboard.ChartData.TicketsByStatus"
								 Title="Tickets by Status"
								 Subtitle="Current ticket distribution by status."
								 EmptyStateMessage="No ticket status data available yet."
								 SeriesName="Tickets" />
	
	</MudItem>
	@* Chart B tickets by priority *@
	<MudItem xs="12" sm="6">
		<DashboardEnumCountChart TEnum="TicketPriority"
								 Items="@Dashboard.ChartData.TicketsByPriority"
								 Title="Tickets by Priority"
								 Subtitle="Current ticket distribution by priority."
								 EmptyStateMessage="No ticket priority data available yet."
								 SeriesName="Tickets" />
	</MudItem>
	@* Chart C  projects by priority *@
	<MudItem xs="12" sm="6">
		<DashboardEnumCountChart TEnum="ProjectPriority"
								 Items="@Dashboard.ChartData.ProjectsByPriority"
								 Title="Projects by Priority"
								 Subtitle="Current project distribution by priority."
								 EmptyStateMessage="No project priority data available yet."
								 SeriesName="Projects" />
	</MudItem>
	@* Chart D tickets by project *@
	<MudItem xs="12">
		<TicketsByProjectChart Items="Dashboard?.ChartData.TicketsByProject" />
	</MudItem>
</MudGrid>

@code {
	[Parameter, EditorRequired]
	public AdminDashboardDTO Dashboard { get; set; } = default!;
}
