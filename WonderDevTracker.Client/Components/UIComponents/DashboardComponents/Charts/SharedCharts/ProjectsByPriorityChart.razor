@* ProjectsByPriorityChart *@



<DashboardChartCard Title="@Title" Subtitle="@Subtitle">
    @if (IsEmpty)
    {
        <DashboardChartEmptyState Message="No project priority data available yet." />
    }
    else
    {
		<ApexChart TItem="DashboardCountByCategoryDTO">
			<ApexPointSeries TItem="DashboardCountByCategoryDTO"
							 Items="@Items"
							 Name="Projects by Priority"
							 SeriesType="SeriesType.Bar"
							 XValue="@(item => item.Label)"
							 YValue="@(item => item.Count)" />
		</ApexChart>
    }
</DashboardChartCard>

    @code {
    [Parameter, EditorRequired]
    public List<DashboardCountByCategoryDTO> Items { get; set; } = [];

    [Parameter]
    public string Title { get; set; } = "Projects by Priority";

    [Parameter]
    public string? Subtitle { get; set; } = "Project distribution by priority.";

    private bool IsEmpty => Items is null || !Items.Any();
}
