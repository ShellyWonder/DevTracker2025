@* ProjectsByPriorityChart *@

@typeparam TItem

<DashboardChartCard Title="@Title" Subtitle="@Subtitle">
    @if (Items is null || !Items.Any())
    {
        <DashboardChartEmptyState Message="No project priority data available yet." />
    }
    else
    {
        @* Apex chart markup goes here *@
    }
</DashboardChartCard>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<TItem> Items { get; set; } = [];

    [Parameter]
    public string Title { get; set; } = "Projects by Priority";

    [Parameter]
    public string? Subtitle { get; set; } = "Project distribution by priority.";
}
