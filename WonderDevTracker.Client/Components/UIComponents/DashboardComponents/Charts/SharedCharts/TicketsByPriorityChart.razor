@* TicketsByPriorityChart.razor *@

<DashboardChartCard Title="@Title" Subtitle="@Subtitle">
	@if (IsEmpty)
	{
		<DashboardChartEmptyState Message="No ticket priority data available yet." />
	}
	else
	{
		<ApexChart TItem="DashboardCountByCategoryDTO">
			<ApexPointSeries TItem="DashboardCountByCategoryDTO"
							 Items="@Items"
							 Name="Tickets"
							 SeriesType="SeriesType.Bar"
							 XValue="@(item => item.Label)"
							 YValue="@(item => item.Count)" />
		</ApexChart>
	}
</DashboardChartCard>

@code {
	[Parameter, EditorRequired]
	public List<DashboardCountByCategoryDTO> Items { get; set; } = [];

	[Parameter]
	public string Title { get; set; } = "Tickets by Priority";

	[Parameter]
	public string? Subtitle { get; set; } = "Current workload grouped by priority.";

	private bool IsEmpty => Items == null || !Items.Any();
}