@* DashboardRecentTickets *@

<MudPaper Class="pa-4 mb-4"
		  Elevation="3">
	<MudStack Row="true"
			  AlignItems="AlignItems.Center"
			  Justify="Justify.SpaceBetween"
			  Class="mb-3">

		<MudStack Row="true"
				  AlignItems="AlignItems.Center"
				  Spacing="2">

			<MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber"
					 Color="Color.Primary"
					 Size="Size.Large" />

			<MudText Typo="Typo.h2" Color="Color.Primary">@Title</MudText>

		</MudStack>
		<MudStack Row="true"
				  AlignItems="AlignItems.Center"
				  Spacing="2">

			<ExpandCollapseToggle @bind-IsExpanded="_expanded" />
		</MudStack>
	</MudStack>

	
	@if (IsSingleTab)
	{
		<DashboardRecentTicketsTable Tickets="VisibleUnassignedTickets"
									 UnassignedTickets="true"
									 AllowAssignment="@AllowAssignment" />
	}
	else
	{
		<MudTabs Rounded="true" Elevation="0">
			<MudTabPanel Text="Active">
				<DashboardRecentTicketsTable Tickets="VisibleActiveTickets" />
			</MudTabPanel>

			<MudTabPanel Text="Resolved">
				<DashboardRecentTicketsTable Tickets="VisibleResolvedTickets"
											 AllowAssignment="false" />
			</MudTabPanel>

			@if (UnassignedTickets?.Any() == true)
			{
				<MudTabPanel Text="Unassigned">
					<DashboardRecentTicketsTable Tickets="VisibleUnassignedTickets"
												 UnassignedTickets="true"
												 AllowAssignment="@AllowAssignment" />
				</MudTabPanel>
			}
		</MudTabs>

	}

</MudPaper>

@code {

	[Parameter]
	public string Title { get; set; } = "Recent Ticket Activity";

	[Parameter]
	public DashboardRecentTicketsMode Mode { get; set; } = DashboardRecentTicketsMode.Tabs;

	[Parameter]
	public IReadOnlyList<DashboardTicketSummaryDTO> ActiveTickets { get; set; } = [];

	[Parameter]
	public IReadOnlyList<DashboardTicketSummaryDTO> ResolvedTickets { get; set; } = [];

	[Parameter]
	public IReadOnlyList<DashboardTicketSummaryDTO> UnassignedTickets { get; set; } = [];

	[Parameter]
	public bool AllowAssignment { get; set; } = true;

	[Parameter]
	public int PreviewCount { get; set; } = 3;

	[Parameter]
	public int Index { get; set; }

	private IReadOnlyList<DashboardTicketSummaryDTO> VisibleActiveTickets =>
	_expanded
		? ActiveTickets
		: ActiveTickets.Take(PreviewCount).ToList();

	private IReadOnlyList<DashboardTicketSummaryDTO> VisibleResolvedTickets =>
		_expanded
			? ResolvedTickets
			: ResolvedTickets.Take(PreviewCount).ToList();

	private IReadOnlyList<DashboardTicketSummaryDTO> VisibleUnassignedTickets =>
		_expanded
			? UnassignedTickets
			: UnassignedTickets.Take(PreviewCount).ToList();
	private bool IsSingleTab => Mode == DashboardRecentTicketsMode.SingleUnassigned;

	private bool _expanded = false;
}
