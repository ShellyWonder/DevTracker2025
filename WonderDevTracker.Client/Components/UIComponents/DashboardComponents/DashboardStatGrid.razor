@* DashboardStatGrid *@

@{
    var stats = Stats?.ToList() ?? [];
}

@if (stats.Any())
{
    <MudGrid Spacing="3">
        @for (var i = 0; i < stats.Count; i++)
        {
            var stat = stats[i];

            <MudItem xs="12" sm="@SmColumns" md="@MdColumns" lg="@LgColumns">
                <DashboardStatCard Index="@i"
                                   Title="@stat.Title"
                                   StatValue="@stat.Value"
                                   DetailsHref="@stat.DetailsHref"
                                   Icon="@stat.Icon"
                                   Color="@stat.Color" />
            </MudItem>
        }
    </MudGrid>
}

@code {

    [Parameter, EditorRequired]
    public IReadOnlyList<DashboardStatItemViewModel> Stats { get; set; } = [];

    [Parameter]
    public int SmColumns { get; set; } = 6;

    [Parameter]
    public int MdColumns { get; set; } = 6;

    [Parameter]
    public int LgColumns { get; set; } = 3;
}