@* DashboardQuickActions.razor *@

<MudPaper Class="dashboard-quick-actions pa-4 mb-3"
          Elevation="2">

    <div class="dashboard-quick-actions-layout">

        <div class="dashboard-quick-actions-heading">
            <MudIcon Icon="@Icons.Material.Filled.Bolt"
                     Color="Color.Primary" />

            <MudText Typo="Typo.h6"
                     Class="dashboard-quick-actions-title">
                Quick Actions
            </MudText>
        </div>

        <div class="dashboard-quick-actions-list">

            @if (CanManageProjects)
            {
                <SafeNavButton Href="/projects/create"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Class="px-2"
                               Size="Size.Small">
                    Create New Project
                </SafeNavButton>
            }

            @if (CanSubmitTickets)
            {
                <SafeNavButton Href="/tickets/create"
                               Color="Color.Secondary"
                               Variant="Variant.Filled"
                               Class="px-2"
                               Size="Size.Small">
                    Submit Ticket
                </SafeNavButton>
            }

            @if (CanManageMembers)
            {
                <SafeNavButton Href="/company#company-members"
                               Color="Color.Tertiary"
                               Variant="Variant.Filled"
                               Class="px-2"
                               Size="Size.Small">
                    Manage Team
                </SafeNavButton>
            }

            @if (CanViewInvites)
            {
                <SafeNavButton Href="/company#company-invites"
                               Color="Color.Warning"
                               Variant="Variant.Filled"
                               Class="px-2"
                               Size="Size.Small">
                    View Invitations
                </SafeNavButton>
            }

            @if (CanViewArchivedTickets)
            {
                <SafeNavButton Href="/tickets/archived"
                               Color="Color.Error"
                               Variant="Variant.Filled"
                               Class="px-2"
                               Size="Size.Small">
                    View Archived Tickets
                </SafeNavButton>
            }

        </div>

    </div>

</MudPaper>

@code {
    [Parameter]
    public bool CanManageProjects { get; set; }

    [Parameter]
    public bool CanManageMembers { get; set; }

    [Parameter]
    public bool CanSubmitTickets { get; set; }

    [Parameter]
    public bool CanViewInvites { get; set; }

    [Parameter]
    public bool CanViewOpenTickets { get; set; }

    [Parameter]
    public bool CanViewArchivedTickets { get; set; }

    [Parameter]
    public bool CanViewMyTickets { get; set; }
}