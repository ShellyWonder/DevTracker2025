@* DashboardQuickActions.razor *@

<div class="dashboard-quick-actions-shell">
	<MudPaper Class="dashboard-quick-actions pa-4 mb-4"
			  Elevation="1"
			  rounded="true">

		<MudStack Row="true"
				  AlignItems="AlignItems.Center"
				  Justify="Justify.SpaceBetween"
				  Class="dashboard-quick-actions-header">

			<MudStack Row="true"
					  AlignItems="AlignItems.Center"
					  Spacing="2">

				<MudIcon Icon="@Icons.Material.Filled.Bolt"
						 Color="Color.Primary" />

				<MudText Typo="Typo.h6"
						 Class="dashboard-quick-actions-title">
					Quick Actions
				</MudText>

			</MudStack>

			<MudStack Row="true"
					  AlignItems="AlignItems.Center"
					  Spacing="2"
					  Class="dashboard-quick-actions-list flex-wrap">

				@if (CanManageProjects)
				{
					<SafeNavButton Href="/projects/create"
								   Color="Color.Primary"
								   Variant="Variant.Filled"
								   Size="Size.Small">
						Create New Project
					</SafeNavButton>
				}

				@if (CanSubmitTickets)
				{
					<SafeNavButton Href="/tickets/create"
								   Color="Color.Secondary"
								   Variant="Variant.Filled"
								   Size="Size.Small">
						Submit Ticket
					</SafeNavButton>
				}

				@if (CanManageMembers)
				{
					<SafeNavButton Href="/company/members"
								   Color="Color.Primary"
								   Variant="Variant.Outlined"
								   Size="Size.Small">
						Manage Team
					</SafeNavButton>
				}
				@if (CanViewInvites)
				{
					<SafeNavButton Href="/company#company-invites"
								   Color="Color.Primary"
								   Variant="Variant.Outlined"
								   Size="Size.Small">
						View Invitations
					</SafeNavButton>
				}
				@if (CanViewOpenTickets)
				{
					<SafeNavButton Href="/tickets/open"
								   Color="Color.Primary"
								   Variant="Variant.Outlined"
								   Size="Size.Small">
						View Open Tickets
					</SafeNavButton>
				}
				@if (CanViewMyTickets)
				{
					<SafeNavButton Href="/tickets/assigned"
								   Color="Color.Primary"
								   Variant="Variant.Outlined"
								   Size="Size.Small">
						View My Tickets
					</SafeNavButton>
				}
				@if (CanViewArchivedTickets)
				{
					<SafeNavButton Href="/tickets/archived"
								   Color="Color.Primary"
								   Variant="Variant.Outlined"
								   Size="Size.Small">
						View Archived Tickets
					</SafeNavButton>
				}

			</MudStack>

		</MudStack>

	</MudPaper>
</div>

@code {
	[Parameter]
	public bool CanManageProjects { get; set; } = false;

	[Parameter]
	public bool CanManageMembers { get; set; } = false;

	[Parameter]
	public bool CanSubmitTickets { get; set; } = false;

	[Parameter]
	public bool CanViewInvites { get; set; } = false;

	[Parameter]
	public bool CanViewOpenTickets { get; set; } = false;

	[Parameter]
	public bool CanViewArchivedTickets { get; set; } = false;

	[Parameter]
	public bool CanViewMyTickets { get; set; } = false;
}