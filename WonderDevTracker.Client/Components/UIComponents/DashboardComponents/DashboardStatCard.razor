@* DashboardStatCard *@
@inject NavigationManager NavManager

<MudPaper Class="@($"dashboard-stat-card {Class}")" Elevation="1">
	<AnimatedCard Index="Index" OnClick="NavigateToDetails" Class="h-100">

		<MudCardContent Class="dashboard-stat-card__content">
			<MudStack Row="true"
					  AlignItems="AlignItems.Center"
					  Justify="Justify.SpaceBetween"
					  Spacing="2"
					  Class="w-100">

				<MudStack Row="true"
						  AlignItems="AlignItems.Center"
						  Spacing="2"
						  Class="dashboard-stat-card__main">

					@if (!string.IsNullOrWhiteSpace(Icon))
					{
						<div class="dashboard-stat-card__icon">
							<MudIcon Icon="@Icon"
									 Color="@Color"
									 Size="@Size" />
						</div>
					}

					<MudText Typo="@Typo"
							 Color="@Color"
							 Align="@Align"
							 Class="dashboard-stat-card__title">
						@Title
					</MudText>

				</MudStack>

				<DashboardStatChip StatValue="@StatValue"
								   Color="@Color"
								   Class="dashboard-stat-card__chip" />

			</MudStack>
		</MudCardContent>

	</AnimatedCard>
</MudPaper>

@code {
	[Parameter, EditorRequired]
	public string Title { get; set; } = default!;

	[Parameter, EditorRequired]
	public int StatValue { get; set; }

	[Parameter, EditorRequired]
	public int Index { get; set; }

	[Parameter, EditorRequired]
	public string DetailsHref { get; set; } = default!;

	[Parameter]
	public string? Icon { get; set; } = MudBlazor.Icons.Material.Filled.QueryStats;

	[Parameter]
	public Color Color { get; set; } = Color.Primary;

	[Parameter]
	public Typo Typo { get; set; } = Typo.h6;

	[Parameter]
	public Align Align { get; set; } = Align.Left;

	[Parameter]
	public string? Class { get; set; } = "h-100";

	[Parameter]
	public Size Size { get; set; } = Size.Medium;

	private void NavigateToDetails()
	{
		if (string.IsNullOrWhiteSpace(DetailsHref)) return;

		NavManager.NavigateTo(DetailsHref);
	}
}