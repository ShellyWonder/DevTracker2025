@* DashboardTeamPanel.razor *@

<MudPaper Class="@($"pa-4 dashboard-team-panel {Class}")"
          Elevation="2">

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Justify="Justify.SpaceBetween"
              Class="mb-3">

        <MudStack Row="true"
                  AlignItems="AlignItems.Center"
                  Spacing="2">

            <MudIcon Icon="@Icons.Material.Filled.Groups"
                     Color="Color.Primary"
                     Size="Size.Large" />

            <MudText Typo="Typo.h2" Color="Color.Primary">@Title</MudText>
        </MudStack>
    </MudStack>

    @if (!_visibleMembers.Any())
    {
        <NotFoundDisplay Message="No team members found." />
    }
    else
    {
        <div class="dashboard-team-role-grid">
            @foreach (var roleGroup in VisibleRoleGroups)
            {

                <MudPaper Class="dashboard-team-role-zone p-3"
                          Elevation="0"
                          Outlined >

                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween"
                              Class="mb-2">

                        <MudText Typo="Typo.button"
                                 Color="Color.Primary">
                            @roleGroup.Role.GetDisplayName()
                        </MudText>

                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="Color.Info"
                                 Variant="Variant.Outlined">
                            @roleGroup.Members.Count
                        </MudChip>

                    </MudStack>

                    @if (!roleGroup.Members.Any())
                    {
                        <NotFoundDisplay Message="@GetEmptyRoleMessage(roleGroup.Role)" />
                    }
                    else
                    {
                        <MudStack Spacing="2" Class="dashboard-team-member-list">
                            @foreach (var member in roleGroup.Members)
                            {
                                <ProjectTeamCard User="@member" />
                            }
                        </MudStack>
                    }

                </MudPaper>
            }
        </div>
    }

</MudPaper>


@code {
    [Parameter, EditorRequired]
    public IEnumerable<AppUserDTO> Members { get; set; } = [];

    [Parameter, EditorRequired]
    public string Title { get; set; }

    [Parameter]
    public bool CanManageMembers { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private IReadOnlyList<AppUserDTO> _visibleMembers = [];

    protected override void OnParametersSet()
    {
        _visibleMembers = Members
        .OrderBy(m => m.Role)
        .ThenBy(m => m.LastName)
        .ThenBy(m => m.FirstName)
        .ToList();
    }

    
    private IEnumerable<RoleMemberGroup> VisibleRoleGroups =>
        VisibleRoles
            .Select(role => new RoleMemberGroup(
                role,
                _visibleMembers
                    .Where(m => m.Role == role)
                    .OrderBy(m => m.LastName)
                    .ThenBy(m => m.FirstName)
                    .ToList()))
            .Where(group => group.Members.Any());

    private static readonly Role[] VisibleRoles =
         [
             Role.Admin,
                Role.ProjectManager,
                Role.Developer,
                Role.Submitter

        ];

    private static string GetEmptyRoleMessage(Role role) =>
        $"No {role.GetDisplayName()}s found.";

    private sealed record RoleMemberGroup(Role Role, IReadOnlyList<AppUserDTO> Members);
}
