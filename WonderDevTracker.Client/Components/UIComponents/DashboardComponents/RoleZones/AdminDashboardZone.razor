@* AdminDashboardZone *@

<MudStack Spacing="4">
	@* Company-wide stat cards  *@
	<DashboardStatGrid Stats="Stats" />

	@* Company-wide stat charts *@  
	<AdminChartsGrid Dashboard="Dashboard" />

	@* Recent projects  *@
	<DashboardProjectActivity Projects="Projects"
							  CollapsedCount="3" />

	@* Recent tickets *@
	<DashboardRecentTickets ActiveTickets="Dashboard.RecentActiveTickets"
							ResolvedTickets="Dashboard.RecentResolvedTickets"
							UnassignedTickets="Dashboard.RecentUnassignedTickets" />

	@* Team/member panel *@
	<DashboardTeamPanel Members="Members"
						CanManageMembers="true" />

</MudStack>

@code {
	[Parameter, EditorRequired]
	public DashboardDTO Dashboard { get; set; } = default!;

	[Parameter, EditorRequired]
	public IReadOnlyList<ProjectDTO> Projects { get; set; } = [];

	[Parameter, EditorRequired]
	public IEnumerable<AppUserDTO> Members { get; set; } = [];

	private IReadOnlyList<DashboardStatItemViewModel> Stats => DashboardStatFactory.BuildStats(Dashboard, Role.Admin);
}