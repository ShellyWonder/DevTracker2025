@* ProjectManagerDashboardZone *@

@if (Dashboard is null)
{
	<DashboardChartEmptyState Message="Dashboard data is not available." />
}
else
{
	<MudStack Spacing="4">
		@* PM-scoped stats *@
		<DashboardStatGrid Stats="Stats" />

		@* PM-scoped charts *@
		<ProjectManagerChartsGrid Dashboard="Dashboard" />

		@* Assigned projects *@
		<DashboardProjectActivity Projects="Dashboard.ManagedProjects" />
		@* Project team activity *@
		<DashboardTeamPanel Members="Dashboard.TeamMembers"
							Title="My Project Teams"
							CanManageMembers="true" />
		@* Unassigned tickets for projects assigned to PM *@
		<DashboardRecentTickets UnassignedTickets="Dashboard.UnassignedTickets"
								AllowAssignment="true" 
								Mode="DashboardRecentTicketsMode.SingleUnassigned"
								Title="Unassigned Tickets"/>

	</MudStack>

}

@code {

	[Parameter, EditorRequired]
	public PMDashboardDTO Dashboard { get; set; } = default!;

	private IReadOnlyList<DashboardStatItemViewModel> Stats =>
		DashboardStatFactory.BuildStats(Dashboard);
}
