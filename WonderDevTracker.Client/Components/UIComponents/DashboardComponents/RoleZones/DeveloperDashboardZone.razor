@* DeveloperDashboardZone *@


@if (Dashboard is null)
{

	<DashboardChartEmptyState Message="Dashboard data is not available." />
}
else
{
	<MudStack Spacing="4">
		<DashboardStatGrid Stats="Stats" />

		@* Assigned tickets *@
		@* Recent ticket updates *@
		@* Projects they are assigned to *@

		@* Developer charts summary *@
		<DeveloperChartsGrid Dashboard="Dashboard" />
	</MudStack>

}

@code {
	[Parameter, EditorRequired]
	public DeveloperDashboardDTO Dashboard { get; set; } = default!;

	[Parameter]
	public IEnumerable<TicketDTO> Tickets { get; set; } = [];

	[Parameter]
	public IEnumerable<ProjectDTO> Projects { get; set; } = [];

	private IReadOnlyList<DashboardStatItemViewModel> Stats => DashboardStatFactory.BuildStats(Dashboard);

	
}
