@* TicketDates *@
@* Displays the project's submitted date and updated date(if available). Accepts two parameters, SubmittedDate and UpdatedDate. *@

@* TicketDates *@
<MudText Typo="Typo.caption" Class="text-secondary">
	Submitted
	<TimestampComponent PrimaryTimestamp="@SubmittedDate"
						DisplayMode="TimestampDisplayMode.Absolute"
						Class="d-inline" />
	@if (UpdatedDate is not null)
	{
		<text>
			<span> &bull;</span>
			Updated <TimestampComponent PrimaryTimestamp="@UpdatedDate"
										DisplayMode="TimestampDisplayMode.Absolute"
										Class="d-inline" />
		</text>
	}
</MudText>

@code {
	[Parameter, EditorRequired]
	public DateTimeOffset? SubmittedDate { get; set; }

	[Parameter]
	public DateTimeOffset? UpdatedDate { get; set; }
}
