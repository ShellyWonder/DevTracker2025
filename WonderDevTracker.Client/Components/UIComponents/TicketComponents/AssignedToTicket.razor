@* AssignedToTicket *@
@inject ICompanyDTOService CompanyService

<div class="d-flex align-items-center gap-2">

	@if (User is null)
	{
		<UnassignedDeveloperLink TicketId="@TicketId" />
	}
	else
	{
		<UserAvatarMudChip User="@User" PlaceholderName="@PlaceholderName" />
	}
</div>

@code {
	[Parameter, EditorRequired]
	public AppUserDTO? User { get; set; }

	[Parameter, EditorRequired]		
	public int TicketId { get; set; }

	[Parameter]
	public string PlaceholderName { get; set; } = "Unassigned";

	[Parameter]
	public string? Class { get; set; }


}
