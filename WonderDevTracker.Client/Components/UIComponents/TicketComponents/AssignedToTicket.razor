@* AssignedToTicket *@

<div class="@CssClass">
    @switch (DisplayMode)
    {
        case AssignmentDisplayMode.LockedUnassigned:
            <NoLinkDevNotAssigned />
            break;

        case AssignmentDisplayMode.AssignableUnassigned:
            <UnassignedDeveloperLink TicketId="@TicketId" />
            break;

        case AssignmentDisplayMode.Assigned:
            <UserAvatarMudChip User="@User" />
            break;
    }
</div>

@code {
    [Parameter]
    public AppUserDTO? User { get; set; }

    [Parameter, EditorRequired]
    public int TicketId { get; set; }

    [Parameter]
    public bool CanAssignDeveloper { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private AssignmentDisplayMode DisplayMode => User switch
    {
        null when !CanAssignDeveloper => AssignmentDisplayMode.LockedUnassigned,
        null => AssignmentDisplayMode.AssignableUnassigned,
        _ => AssignmentDisplayMode.Assigned
    };

    private string CssClass =>
        string.IsNullOrWhiteSpace(Class)
            ? "d-flex align-items-center justify-content-center gap-2"
            : $"d-flex align-items-center gap-2 {Class}";

    private enum AssignmentDisplayMode
    {
        LockedUnassigned,
        AssignableUnassigned,
        Assigned
    }
}