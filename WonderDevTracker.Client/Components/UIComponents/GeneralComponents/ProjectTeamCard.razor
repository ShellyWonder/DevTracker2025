@* ProjectTeamCard *@

@inject ICompanyDTOService CompanyService


<div class="d-flex align-items-center gap-2">
	
		<UserAvatarComponent ImageUrl="@User?.ImageUrl"
							 Initials="@User?.Initials"
							 FullName="@User?.FullName"
							 AltText="@User?.FullName"
							 Size="Size.Medium"
							 Class="project-card-member-avatar" 
							 Featured="true"/>
	

	<div>
		<MudText Typo="Typo.body1" Color="Color.Primary">@(User?.FullName ?? PlaceholderName)</MudText>
		<MudText Typo="Typo.caption" Color="Color.Secondary">@(User?.Role?.GetDisplayName() ?? PlaceholderRole)</MudText>
		
	</div>

</div>


@code {
	[Parameter, EditorRequired]
	public AppUserDTO? User { get; set; }

	[Parameter]
	public string PlaceholderName { get; set; } = "Unassigned";

	[Parameter]
	public string PlaceholderRole { get; set; } = "Unknown Role";

	[Parameter]
	public string? Class { get; set; }
	[Parameter] 
	public bool IsPM { get; set; }

	private IEnumerable<AppUserDTO> projectManagers = [];

}
