@* LandingCallToAction *@

<div class="landing-cta-card">
    <p class="landing-eyebrow text-only">Ready to explore?</p>
    <h2>Start with a demo role and walk through the DevTracker workflow.</h2>
    <p>
        Review dashboards, inspect tickets, explore project activity, and see how the app
        adapts to each user role.
    </p>

    <div class="hero-actions center">
        <CtaBtn Href="#demo"
                StartIcon="@Icons.Material.Filled.PlayArrow"
                Class="rounded-pill text-none font-weight-bold"
                BtnText="Try the Demo" />

        <CtaBtn Href="/Account/Login"
                Variant="Variant.Outlined"
                Class="rounded-pill text-none font-weight-bold"
                BtnText="Log In" />
    </div>
</div>
