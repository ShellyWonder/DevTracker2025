@* LandingDemoAccess *@
<MudGrid Spacing="4" AlignItems="Center">
    <MudItem xs="12" md="5">
        <div class="section-heading left-align">
            <p class="landing-eyebrow text-only">Demo Access</p>
            <h2>Preview DevTracker from different permission levels.</h2>
            <p>
                Use a demo role to see how dashboards, tickets, projects, and actions
                change depending on the user’s responsibilities.
            </p>
        </div>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudGrid Spacing="3">
            @foreach (DemoCard demo in DemoCards)
            {
                <MudItem xs="12" sm="6">
                    <article class="demo-card" @key="demo.Role">
                        <div>
                            <span class="demo-role">@demo.RoleName</span>
                            <h3 class="mt-2">@demo.Title</h3>
                            <p>@demo.Description</p>
                        </div>

                        <LinksBtn Href="@GetDemoHref(demo.Role)"
                                  Text="Launch Demo"
                                  Color="Color.Primary" />

                    </article>
                </MudItem>
            }
        </MudGrid>
    </MudItem>
</MudGrid>

@code {
    private sealed record DemoCard(
       Role Role,
       string RoleName,
       string Title,
       string Description,
       string Href
    );

    private readonly List<DemoCard> DemoCards =
[
    new( 
            Role.Admin,
            "Admin",
            "Company-wide control",
            "Preview full access to users, projects, tickets, dashboards, and administrative workflows.",
            "/Account/Login?demoRole=Admin"),

        new(
            Role.ProjectManager,
            "Project Manager",
            "Project oversight",
            "Preview project-level management, team visibility, unassigned tickets, and PM dashboard insights.",
            "/Account/Login?demoRole=ProjectManager"),

        new(
            Role.Developer,
            "Developer",
            "Assigned work queue",
            "Preview a developer-focused dashboard with assigned tickets, project context, and status tracking.",
            "/Account/Login?demoRole=Developer"),

        new(
            Role.Submitter,
            "Submitter",
            "Ticket submission flow",
            "Preview the experience for submitting tickets and tracking submitted work.",
            "/Account/Login?demoRole=Submitter")
];

    private static string GetDemoHref(Role role) => $"/Account/Login?demoRole={role}";
}
