@* NotificationCard *@
@* This component is used to wrap the NotificationTable component
and provide a consistent layout and styling for the notifications section of the dashboard. *@

@inject INotificationDTOService NotificationService
@inject NotificationStateService NotificationState
@inject ISnackbar Snackbar
@inherits AuthenticatedComponentBase


@if (IsEmpty)
{
	<NotFoundDisplay Message="All caught up! No notifications to display." />
}
else
{
	<MudTabs Elevation="0"
			 Rounded="true"
			 ApplyEffectsToContainer="true"
			 PanelClass="pa-2 pt-2">
		<MudTabPanel Text="Active Notifications">
			<NotificationTable Notifications="@VisibleActiveNotifications"
							   Index="@Index"
							   OnShowSourceRequested="HandleShowSourceAsync"
							   OnMarkReadRequested="HandleMarkReadAsync"
							   OnMarkUnreadRequested="HandleMarkUnreadAsync"
							   OnDismissRequested="HandleDismissAsync"
							   OnMarkAllReadRequested="HandleMarkAllReadAsync" />
		</MudTabPanel>

		<MudTabPanel Text="Dismissed Notifications">
			<NotificationTable Notifications="@VisibleDismissedNotifications"
							   Index="@Index"
							   IsArchived="true"
							   OnShowSourceRequested="HandleShowSourceAsync"
							   OnRestoreRequested="HandleRestoreAsync" />
		</MudTabPanel>
	</MudTabs>
}

@code {

	#region PARAMETERS
	[Parameter]
	public List<NotificationDTO> Notifications { get; set; } = new();

	[Parameter]
	public List<NotificationDTO> DismissedNotifications { get; set; } = [];

	[Parameter]
	public int Index { get; set; }

	[Parameter]
	public EventCallback<int> OnMarkReadRequested { get; set; }

	[Parameter]
	public EventCallback<int> OnArchived { get; set; }

	[Parameter]
	public EventCallback<int> OnRestored { get; set; }

	[Parameter]
	public EventCallback<NotificationDTO> OnOpen { get; set; }

	[Parameter]
	public EventCallback OnNotificationsChanged { get; set; }

	[Parameter]
	public int PreviewCount { get; set; } = 3;

	[Parameter]
	public bool IsExpanded { get; set; }
	#endregion

	#region COMPUTED PROPERTIES
	// Note:API already returns current-user notifications
	private List<NotificationDTO> ActiveNotifications => Notifications
	.Where(n => !n.IsArchived)
	.ToList();

	private List<NotificationDTO> VisibleActiveNotifications =>
		IsExpanded
			? ActiveNotifications
			: ActiveNotifications.Take(PreviewCount).ToList();

	private List<NotificationDTO> VisibleDismissedNotifications =>
		IsExpanded
			? DismissedNotifications
			: DismissedNotifications.Take(PreviewCount).ToList();

	private bool IsEmpty => Notifications.Count == 0;
	#endregion

	#region EVENT HANDLERS

	private async Task HandleMarkReadAsync(int notificationId)
	{
		if (UserInfo is null) return;

		await NotificationService.MarkReadAsync(notificationId, UserInfo.UserId);
		await NotificationState.RefreshUnreadCountAsync(UserInfo);
		await OnNotificationsChanged.InvokeAsync();
	}

	private async Task HandleMarkUnreadAsync(int notificationId)
	{
		if (UserInfo is null) return;

		await NotificationService.MarkUnreadAsync(notificationId, UserInfo.UserId);
		await NotificationState.RefreshUnreadCountAsync(UserInfo);
		await OnNotificationsChanged.InvokeAsync();
	}

	private async Task HandleDismissAsync(int notificationId)
	{

		if (UserInfo is null) return;

		try
		{
			await NotificationService.ArchiveNotificationAsync(
									notificationId,
									UserInfo.UserId,
									IsAdmin);
			await NotificationState.RefreshUnreadCountAsync(UserInfo);
			await OnNotificationsChanged.InvokeAsync();
		}
		catch (Exception)
		{
			
			Snackbar.Add("Unable to dismiss notification.", Severity.Error);
		}
	}

	private async Task HandleRestoreAsync(int notificationId)
	{
		if (UserInfo is null) return;

		await NotificationService.RestoreNotificationAsync(
			notificationId,
			UserInfo.UserId,
			IsAdmin);

		await NotificationState.RefreshUnreadCountAsync(UserInfo);
		await OnNotificationsChanged.InvokeAsync();
	}

	private async Task HandleMarkAllReadAsync()
	{
		if (UserInfo is null) return;

		await NotificationService.MarkAllReadAsync(UserInfo);
		await NotificationState.RefreshUnreadCountAsync(UserInfo);
		await OnNotificationsChanged.InvokeAsync();
	}

	private async Task HandleShowSourceAsync(NotificationDTO notification) =>
			await OnOpen.InvokeAsync(notification);
	
	#endregion
}
