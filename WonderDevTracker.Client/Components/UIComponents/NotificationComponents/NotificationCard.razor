@* NotificationCard *@
@* This component is used to wrap the NotificationTable component
and provide a consistent layout and styling for the notifications section of the dashboard. *@

@inject INotificationDTOService NotificationService

@inherits AuthenticatedComponentBase

<AnimatedCard Index="@Index">
	<MudCardHeader>
		<MudText Typo="Typo.h3" Color="Color.Primary">Notifications</MudText>
	</MudCardHeader>
	<MudCardContent>
		@if (Notifications.Count == 0)
		{
			<NotFoundDisplay Message="No notifications available" />
		}
		else
		{
			<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">

				<MudTabPanel Text="Active Notifications">
					<NotificationTable Notifications="@ActiveNotifications"
									   Index="@Index"
									   OnMarkViewed="OnMarkViewed"
									   OnArchived="OnArchived"
									   OnMarkAllViewed="HandleMarkAllViewedAsync" />
				</MudTabPanel>

				<MudTabPanel Text="Dismissed Notifications">
					<NotificationTable Notifications="@DismissedNotifications"
									   Index="@Index"
									   OnMarkViewed="OnMarkViewed"
									   IsArchived="true"
									   OnRestored="OnRestored"
									   OnMarkAllViewed="HandleMarkAllViewedAsync" />
				</MudTabPanel>
			</MudTabs>
		}
	</MudCardContent>
</AnimatedCard>

@code {

	#region PARAMETERS
	[Parameter]
	public List<NotificationDTO> Notifications { get; set; } = new();

	[Parameter, EditorRequired]
	public int Index { get; set; }

	[Parameter]
	public EventCallback<int> OnMarkViewed { get; set; }

	[Parameter]
	public EventCallback<int> OnArchived { get; set; }

	[Parameter]
	public EventCallback<int> OnRestored { get; set; }

	[Parameter]
	public EventCallback<NotificationDTO> OnOpen { get; set; }
#endregion

#region PRIVATE PROPERTIES
	// Note:API already returns current-user notifications
	private List<NotificationDTO> ActiveNotifications => Notifications
								.Where(n => !n.IsArchived)
								.ToList();
	private List<NotificationDTO> DismissedNotifications => Notifications
								 .Where(n => n.IsArchived)
								 .ToList();

	private async Task HandleMarkAllViewedAsync()
	{
		if (UserInfo is null) return;

		await NotificationService.MarkAllViewedAsync(UserInfo);

		foreach (var notification in Notifications.Where(n => !n.HasBeenViewed && !n.IsArchived))
		{
			notification.HasBeenViewed = true;
		}

	}
	#endregion
}
