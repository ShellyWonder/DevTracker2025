@* NotificationTable *@

@if (!IsArchived)
{
	<MudToolBar>
		<MudSwitch T="bool"
				   @bind-Value="_unreadOnly"
				   Color="Color.Error"
				   Label="Unread Only" />
		<MudSpacer />
		<MudButton Color="Color.Tertiary"
				   Variant="Variant.Text"
				   Style="font-weight: bold;"
				   Disabled="@(!Notifications.Any(n => !n.HasBeenViewed))"
				   OnClick="OnMarkAllReadRequested">
			Mark all as Read
		</MudButton>
	</MudToolBar>
}
<MudDataGrid Items="FilteredNotifications"
			 Elevation="0"
			 Dense="true"
			 ColumnResizeMode="ResizeMode.Container"
			 DragDropColumnReordering
			 Hideable
			 RowsPerPage="10">
	<Columns>
		<TemplateColumn Title="Status">
			<CellTemplate>
				<MudChip T="string"
						 Color="@GetViewedChipColor(context.Item)"
						 Variant="Variant.Filled"
						 Size="Size.Medium">
					@GetViewedChipLabel(context.Item)
				</MudChip>
			</CellTemplate>
		</TemplateColumn>

		@* enum company/ticket/project *@
		<PropertyColumn Property="n => n.Type">
			<CellTemplate>
				<NotificationTypeChip Type="@context.Item.Type" />
			</CellTemplate>
		</PropertyColumn>
		<TemplateColumn Title="Date"
						Sortable="true"
						SortBy="n => n.ArchivedAt.GetValueOrDefault(n.Created)">

			<CellTemplate Context="notification">
				<TimestampComponent PrimaryTimestamp="@notification.Item.ArchivedAt"
									FallbackTimestamp="@notification.Item.Created"
									DisplayMode="TimestampDisplayMode.Absolute" />
			</CellTemplate>
		</TemplateColumn>

		<PropertyColumn Property="n => n.Title">
			<CellTemplate>
				<MudText Typo="Typo.body2" Color="Color.Dark">
					@context.Item.Title
				</MudText>
			</CellTemplate>
		</PropertyColumn>
		<PropertyColumn Property="n => n.Message">
			<CellTemplate>
				<MudText Class="text-truncate" Style="max-width: 600px;">
					@context.Item.Message
				</MudText>
			</CellTemplate>
		</PropertyColumn>

		
		<TemplateColumn Title="Actions">
			<CellTemplate>
				@{
					var notification = context.Item;
					var link = GetNotificationLink(notification);
				}
				<NotificationActionButtons Notification="@notification"
										   IsArchived="@IsArchived"
										   SourceUrl="@link"
										   OnShowSourceRequested="@OnShowSourceRequested"
										   OnMarkReadRequested="@OnMarkReadRequested"
										   OnMarkUnreadRequested="@OnMarkUnreadRequested"
										   OnDismissRequested="@OnDismissRequested"
										   OnRestoreRequested="@OnRestoreRequested" />
			</CellTemplate>
		</TemplateColumn>

	</Columns>
	<PagerContent>
		<MudDataGridPager />
	</PagerContent>
	<NoRecordsContent>
		<NotFoundDisplay Message="No notifications available" />
	</NoRecordsContent>
</MudDataGrid>

@code {
	#region PARAMETERS
	[Parameter, EditorRequired]
	public List<NotificationDTO> Notifications { get; set; } = [];

	[Parameter, EditorRequired]
	public int Index { get; set; }

	[Parameter]
	public bool IsArchived { get; set; }

	[Parameter]
	public EventCallback<NotificationDTO> OnShowSourceRequested { get; set; }

	[Parameter]
	public EventCallback<int> OnMarkReadRequested { get; set; }

	[Parameter]
	public EventCallback<int> OnMarkUnreadRequested { get; set; }

	[Parameter]
	public EventCallback<int> OnDismissRequested { get; set; }

	[Parameter]
	public EventCallback<int> OnRestoreRequested { get; set; }

	[Parameter]
	public EventCallback OnMarkAllReadRequested { get; set; }
	#endregion

	#region PRIVATE FIELDS
	private bool _unreadOnly;

	private IEnumerable<NotificationDTO> FilteredNotifications => _unreadOnly ?
							Notifications.Where(n => !n.HasBeenViewed) :
							Notifications;

	private string? GetNotificationLink(NotificationDTO n)
	{
		if (n.TicketId is not null)
			return $"/tickets/{n.TicketId}";

		if (n.ProjectId is not null)
			return $"/projects/{n.ProjectId}";

		return null;
	}

	private static Color GetViewedChipColor(NotificationDTO notification) =>
	notification.HasBeenViewed ? Color.Tertiary : Color.Error;

	private static string GetViewedChipLabel(NotificationDTO notification) =>
	notification.HasBeenViewed ? "Read" : "Unread";
	#endregion
}
