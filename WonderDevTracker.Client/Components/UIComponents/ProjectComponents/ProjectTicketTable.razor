@* ProjectTicketTable *@

<MudDataGrid Items="Tickets"
			 Elevation="0"
			 Dense="true"
			 ColumnResizeMode="ResizeMode.Container"
			 DragDropColumnReordering
			 Hideable
			 ShowMenuIcon
			 RowsPerPage="10">
	<Columns>
		<PropertyColumn Property="t => t.Title" Title="Ticket">
			<CellTemplate Context="ticket">
				<TicketTitleLink TicketId="ticket.Item.Id"
								 Title="@ticket.Item.Title" />
			</CellTemplate>
		</PropertyColumn>
		<PropertyColumn Property="t => t.Priority">
			<CellTemplate>
				<TicketPriorityChip Priority="@context.Item.Priority" />
			</CellTemplate>
		</PropertyColumn>
		<PropertyColumn Property="t => t.Status">
			<CellTemplate>
				<TicketStatusChip Status="@context.Item.Status" />
			</CellTemplate>
		</PropertyColumn>
		<TemplateColumn Title="Submitter"
						Sortable="true"
						SortBy="c => c.SubmitterUser?.FullName"
						ShowColumnOptions="true">
			<CellTemplate>
				<AssignedToTicket User="@context.Item.SubmitterUser" TicketId="@context.Item.Id" />
			</CellTemplate>
		</TemplateColumn>
		<TemplateColumn Title="Developer"
						Sortable="true"
						SortBy="c => c.DeveloperUser?.FullName"
						ShowColumnOptions="true">
			<CellTemplate>
				<AssignedToTicket User="@context.Item.DeveloperUser" TicketId="@context.Item.Id" />
			</CellTemplate>
		</TemplateColumn>
		<TemplateColumn Title="Updated">
			<CellTemplate Context="ticket">
				<TimestampComponent PrimaryTimestamp="@ticket.Item.Modified" 
									DisplayMode="TimestampDisplayMode.Absolute"/>
			</CellTemplate>
		</TemplateColumn>
	</Columns>
	<PagerContent>
		<MudDataGridPager />
	</PagerContent>
	<NoRecordsContent>
		<NotFoundDisplay Message="No tickets available" />
	</NoRecordsContent>
</MudDataGrid>

<SafeNavButton Href="/tickets/create"
			   Valid="true"
			   Color="Color.Tertiary"
			   Variant="Variant.Text"
			   Class="project-details-link ms-auto"
			   StartIcon="@Icons.Material.Filled.List"
			   TypeText="Add Tickets" />

@code {
	[Parameter, EditorRequired]
	public IEnumerable<TicketDTO> Tickets { get; set; } = [];



}
