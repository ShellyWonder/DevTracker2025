@* ProjectTitleLink.razor *@

@if (ProjectId is null)
{
	<MudText Typo="Typo.caption" Color="Color.Secondary">
		Unknown
	</MudText>
}
else
{
	<SafeNavLink Href="@ProjectUrl"
				 Valid=" ValidProject"
				 Class="project-details-link"
	             Typo="Typo.inherit">
		@ProjectName
	</SafeNavLink>
}

@code {
	[Parameter, EditorRequired]
	public int? ProjectId { get; set; }

	[Parameter, EditorRequired]
	public String? ProjectName { get; set; }

	private string ProjectUrl =>
		ProjectId.HasValue ? $"/projects/{ProjectId.Value}" : "#";

	private bool ValidProject =>
		 ProjectId.HasValue;
}

