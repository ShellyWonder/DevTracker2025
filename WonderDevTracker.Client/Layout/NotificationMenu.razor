@* NotificationMenu *@

@using WonderDevTracker.Client.Helpers

@inject NavigationManager NavManager
@inject INotificationDTOService NotificationService
@inject NotificationStateService NotificationState

@implements IDisposable

@inherits AuthenticatedComponentBase

<MudMenu Icon="@Icons.Material.Filled.Notifications"
		 Color="Color.Inherit"
		 AnchorOrigin="Origin.BottomLeft"
		 TransformOrigin="Origin.TopRight"
		 Size="Size.Small"
		 Dense
		 offsetY="true">

	<ActivatorContent>
		<MudBadge Content="@NotificationState.UnreadCount"
		          Visible="@(NotificationState.UnreadCount > 0)"
				  Color="Color.Error"
				  Overlap="true">
			<MudIconButton Icon="@Icons.Material.Filled.Notifications"
						   Color="Color.Inherit"
						   Size="Size.Medium"
						   ariaLabel="Notifications" />
		</MudBadge>
	</ActivatorContent>
	<ChildContent>
		@if (IsLoading)
		{
			<MudMenuItem Disabled="true">
				<LoadingSpinner Message="Loading Notifications..." Color="Color.Primary" Size="Size.Large" />
			</MudMenuItem>

		}
		else if (Notifications.Count == 0)
		{

			<MudMenuItem Disabled="true">
				<div class="py-5 text-center">
					<MudText Typo="Typo.button" Color="Color.Secondary">No new notifications- You're all caught up!</MudText>
				</div>
			</MudMenuItem>

		}
		else
		{
			@foreach (var notification in Notifications)
			{

				<MudMenuItem OnClick="() => OpenNotificationAsync(notification)">
					<div class="notification-menu-item @(notification.HasBeenViewed ? "read" : "unread")">

						<div class="notification-menu-top-row">
							@if (!notification.HasBeenViewed)
							{
								<span class="notification-unread-dot"></span>
							}

							<MudText Typo="Typo.subtitle2" Class="notification-title">
								@notification.Title
							</MudText>
						</div>
						<div class="notification-menu-message-wrapper">
							<TruncatedTooltipText Text="@notification.Message"
												  Typo="Typo.body2"
												  Placement="Placement.Left" />
						</div>
						<MudText Typo="Typo.caption" Class="notification-timestamp">
							@DateTimeHelper.FormatTimestamp(notification.Created)
						</MudText>
					</div>
				</MudMenuItem>
			}

			<MudDivider />

			<MudMenuItem OnClick="GoToNotificationCenter">
				<MudText Typo="Typo.button">View all Notifications</MudText>
			</MudMenuItem>
		}
	</ChildContent>
</MudMenu>

@code {

	#region STATE

	private const int Take = 5;
	private bool IsLoading = true;
	private List<NotificationDTO> Notifications = [];
	#endregion

	#region LIFECYCLE
	protected override async Task OnInitializedWithAuthAsync()
	{
		if (!IsAuthenticated || UserInfo is null)
			return;
		NotificationState.OnChange += StateHasChanged;
		await LoadMenuAsync();
	}
	#endregion

	#region PRIVATE METHODS
	private async Task LoadMenuAsync()
	{
		IsLoading = true;

		try
		{
			await NotificationState.RefreshUnreadCountAsync(UserInfo!);
			Notifications = await NotificationService
				.GetForCurrentUserAsync(UserInfo!.UserId, Take);
		}
		finally
		{
			IsLoading = false;
		}
	}
	private async Task OpenNotificationAsync(NotificationDTO notification)
	{
		if (!notification.HasBeenViewed)
		{
			await NotificationService.MarkReadAsync(notification.Id, UserInfo!.UserId);
			notification.HasBeenViewed = true;

			await NotificationState.RefreshUnreadCountAsync(UserInfo);
		}

		NavManager.NavigateTo(GetNotificationTarget(notification));
	}

	private void GoToNotificationCenter()	=> NavManager.NavigateTo("/dashboard");

	private static string GetNotificationTarget(NotificationDTO notification)
	{
		if (notification.TicketId is int ticketId)
			return $"/tickets/{ticketId}";

		if (notification.ProjectId is int projectId)
			return $"/projects/{projectId}";

		return "/dashboard";
	}
	#endregion

	public void Dispose() => NotificationState.OnChange -= StateHasChanged;
			
}

