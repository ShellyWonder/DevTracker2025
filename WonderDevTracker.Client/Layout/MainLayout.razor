@inject ThemeManagerService themeService
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificationStateService NotificationState
@implements IDisposable
@inherits LayoutComponentBase



<!-- restored and verified -->
@* Required *@
<!-- v8: self-closing -->
<MudThemeProvider Theme="@themeService.CurrentTheme" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
   
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@(() => DrawerToggle())" />
        <AppLogo />
        <div class="ms-auto">
            <AuthorizeView>
                <Authorized>
                    <NotificationMenu />
                </Authorized>
            </AuthorizeView>
        </div>
    </MudAppBar>


    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="h-100 d-flex flex-column">
        <main class="flex-grow-1 pb-3">
            @Body
        </main>
        <footer>
            <Footer />
        </footer>

        <div id="blazor-error-ui">
            An unhandled error has occurred.
            <a href="" class="reload">Reload</a>
            <a class="dismiss">🗙</a>
        </div>

    </MudMainContent>
</MudLayout>



@code {
	#region STATE
    bool _drawerOpen = true;

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private bool _initialized = false;

    public void Dispose()
    {
        // CRITICAL: unsubscribe to avoid StateHasChanged on a disposed layout
        themeService.OnThemeChanged -= StateHasChanged;
        
    }
    #endregion

	#region UI HELPERS & COMPUTED
    protected override async Task OnInitializedAsync()
    {

		var authState = await AuthStateProvider.GetAuthenticationStateAsync();
		var userInfo = UserInfoHelper.GetUserInfo(authState.User);

        if (userInfo is not null)
        {
            await NotificationState.RefreshUnreadCountAsync(userInfo);
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            //checking local storage for theme preference
            await themeService.InitializeAsync();
            themeService.OnThemeChanged += StateHasChanged;
            _initialized = true;
            StateHasChanged(); // re-render with correct theme
        }
    }
	#endregion

}
