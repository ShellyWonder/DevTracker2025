@* NotificationMenu *@

@using WonderDevTracker.Client.Helpers

@inject NavigationManager NavManager
@inject INotificationDTOService NotificationService
@inject NotificationStateService NotificationState

@implements IDisposable

@inherits AuthenticatedComponentBase

<MudMenu Icon="@Icons.Material.Filled.Notifications"
		 Color="Color.Inherit"
		 AnchorOrigin="Origin.BottomLeft"
		 TransformOrigin="Origin.TopRight"
		 Size="Size.Small"
		 Dense
		 OffsetY="true">

	<ActivatorContent>
		<MudBadge Content="@NotificationState.UnreadCount"
				  Visible="@(NotificationState.UnreadCount > 0)"
				  Color="Color.Error"
				  Overlap="true">
			<MudIconButton Icon="@Icons.Material.Filled.Notifications"
						   Color="Color.Inherit"
						   Size="Size.Medium"
						   ariaLabel="Notifications" />
		</MudBadge>
	</ActivatorContent>
	<ChildContent>
		@if (IsLoading)
		{
			<MudMenuItem Disabled="true">
				<LoadingSpinner Message="Loading Notifications..." Color="Color.Primary" Size="Size.Large" />
			</MudMenuItem>

		}
		else if (Notifications.Count == 0)
		{

			<MudMenuItem Disabled="true">
				<div class="py-5 text-center">
					<MudText Typo="Typo.button" Color="Color.Primary">No new notifications- You're all caught up!</MudText>
				</div>
			</MudMenuItem>

		}
		else
		{
			@foreach (var notification in Notifications)
			{
				<MudMenuItem>
					<div class="notification-menu-item @(notification.HasBeenViewed ? "read" : "unread")">
						<div class="notification-menu-click-target" @onclick="() => OpenNotificationAsync(notification)">
							<div class="notification-menu-top-row">
								@if (!notification.HasBeenViewed)
								{
									<span class="notification-unread-dot"></span>
								}

								<MudText Typo="Typo.button" Color="Color.Primary" Class="notification-title">
									@notification.Title
								</MudText>
							</div>
							<div class="notification-menu-message-wrapper">
								<TruncatedTooltipText Text="@notification.Message"
													  Typo="Typo.body2"
													  Placement="Placement.Left" />
							</div>
							<MudText Typo="Typo.caption" Color="Color.Dark" Class="notification-timestamp">
								@DateTimeHelper.FormatTimestamp(notification.Created)
							</MudText>
						</div>
					</div>

					<div class="notification-menu-actions" @onclick:stopPropagation="true">
						<NotificationActionButtons Notification="notification"
												   Busy="IsLoading"
												   SourceUrl="@GetNotificationTarget(notification)"
												   ShowView="false"
												   ShowRestore="false"
												   OnMarkReadRequested="MarkReadFromMenuAsync"
												   OnMarkUnreadRequested="MarkUnreadFromMenuAsync"
												   OnDismissRequested="DismissFromMenuAsync" />
					</div>

				</MudMenuItem>
			}

			<MudDivider />

			<MudMenuItem OnClick="GoToNotificationCenter">
				<MudText Typo="Typo.button">View all Notifications</MudText>
			</MudMenuItem>
		}
	</ChildContent>
</MudMenu>

@code {

	#region STATE
	private const int Take = 5;
	private bool IsLoading = true;
	private List<NotificationDTO> Notifications = [];
	#endregion

	#region LIFECYCLE
	protected override async Task OnInitializedWithAuthAsync()
	{
		if (!IsAuthenticated || UserInfo is null)
			return;

		NotificationState.OnChange += HandleNotificationStateChanged;

		await LoadMenuAsync();
	}
	#endregion

	#region EVENT HANDLERS
	private void HandleNotificationStateChanged()
	{
		_ = InvokeAsync(async () =>
		{
			if (UserInfo is null)
				return;

			Notifications = await NotificationService
				.GetForCurrentUserAsync(UserInfo.UserId, Take);

			StateHasChanged();
		});
	}

	private async Task LoadMenuAsync()
	{
		IsLoading = true;

		try
		{
			await NotificationState.RefreshUnreadCountAsync(UserInfo!);
			Notifications = await NotificationService
				.GetForCurrentUserAsync(UserInfo!.UserId, Take);
		}
		finally
		{
			IsLoading = false;
		}
	}
	private async Task OpenNotificationAsync(NotificationDTO notification)
	{
		if (!notification.HasBeenViewed)
		{
			await NotificationService.MarkReadAsync(notification.Id, UserInfo!.UserId);
			notification.HasBeenViewed = true;

			await NotificationState.RefreshUnreadCountAsync(UserInfo);
		}

		NavManager.NavigateTo(GetNotificationTarget(notification));
	}
	private async Task MarkReadFromMenuAsync(int notificationId)
	{
		if (UserInfo is null)
			return;

		await NotificationService.MarkReadAsync(notificationId, UserInfo.UserId);

		var notification = Notifications.FirstOrDefault(n => n.Id == notificationId);
		if (notification is not null)
			notification.HasBeenViewed = true;

		await NotificationState.RefreshUnreadCountAsync(UserInfo);
	}

	private async Task MarkUnreadFromMenuAsync(int notificationId)
	{
		if (UserInfo is null)
			return;

		await NotificationService.MarkUnreadAsync(notificationId, UserInfo.UserId);

		var notification = Notifications.FirstOrDefault(n => n.Id == notificationId);
		if (notification is not null)
			notification.HasBeenViewed = false;

		await NotificationState.RefreshUnreadCountAsync(UserInfo);
	}

	private async Task DismissFromMenuAsync(int notificationId)
	{
		if (UserInfo is null)
			return;

		await NotificationService.ArchiveNotificationAsync(
			notificationId,
			UserInfo.UserId,
			IsAdmin);

		Notifications.RemoveAll(n => n.Id == notificationId);

		await NotificationState.RefreshUnreadCountAsync(UserInfo);
	}
	#endregion

	#region NAVIGATION
	private void GoToNotificationCenter() => NavManager.NavigateTo("/dashboard#notifications-table");

	private static string GetNotificationTarget(NotificationDTO notification)
	{
		if (notification.TicketId is int ticketId)
			return $"/tickets/{ticketId}";

		if (notification.ProjectId is int projectId)
			return $"/projects/{projectId}";

		return "/dashboard";
	}
	#endregion

	public void Dispose() => NotificationState.OnChange -= HandleNotificationStateChanged;

}

